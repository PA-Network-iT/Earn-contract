# Network
RPC_URL=

DEPLOYER_PRIVATE_KEY=

# Earn deployment params
EARN_ADMIN=0x0000000000000000000000000000000000000000
EARN_ASSET=0x0000000000000000000000000000000000000000

# Mock token deployment (optional)
# Example: 1000000 USDC (6 decimals) => 1000000000000
MOCK_USDC_MINT_TO=0x0000000000000000000000000000000000000000
MOCK_USDC_MINT_AMOUNT=0

# Earn proxy address (set after deployment)
EARN_PROXY=0x0000000000000000000000000000000000000000

# Share token address (set after DeployEarnShareToken)
EARN_SHARE_TOKEN=0x0000000000000000000000000000000000000000

# Use the default-admin signer for BindShareToken when admin is an EOA.
# If admin is a multisig/timelock, submit setShareToken(address) through that admin instead.
BIND_SHARE_TOKEN_PRIVATE_KEY=

# Use the default-admin signer for ConfigureRoles when admin is an EOA.
# If admin is a multisig/timelock, grant roles through that admin instead.
CONFIGURE_ROLES_PRIVATE_KEY=

# Optional role split (use same address as EARN_ADMIN if no split)
ROLE_PARAMETER_MANAGER=0x0000000000000000000000000000000000000000
ROLE_TREASURY_MANAGER=0x0000000000000000000000000000000000000000
ROLE_COMPLIANCE=0x0000000000000000000000000000000000000000
ROLE_REPORTER=0x0000000000000000000000000000000000000000
ROLE_PAUSER=0x0000000000000000000000000000000000000000
ROLE_UPGRADER=0x0000000000000000000000000000000000000000

ETHERSCAN_API_KEY=
